# IA-service Client — Environment Variables
# Copy this file to .env and fill in real values.
# In production (Render), set these directly in the Environment Variables dashboard.

# ── IA Provider (Groq) ────────────────────────────────
# REQUIRED — service refuses to start without this.
GROQ_API_KEY_CHAT=
GROQ_API_KEY_TEST=

# ── Image Editing (Clipdrop) ──────────────────────────
# REQUIRED — service refuses to start without this.
CLIPDROP_API_KEY=

# ── CORS ──────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Flask server port ─────────────────────────────────
PORT=5000

# ── Backend Java URL ──────────────────────────────────
# Used by the MCP server to fetch the product catalogue.
BACKEND_BASE=http://localhost:8080/api


# ── LLM timeout ───────────────────────────────────────
# Seconds before a 504 is returned to the caller.
LLM_TIMEOUT_SECONDS=45

# ── AI Model ─────────────────────────────────────────
# Override to switch LLM without code changes.
AI_MODEL=groq/llama-3.3-70b-versatile

# ── Log level ─────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO