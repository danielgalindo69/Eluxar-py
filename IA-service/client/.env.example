# ── GOOGLE AI ─────────────────────────────────────────────────────────────────
# API Key de Google Gemini (obtenida desde Google AI Studio)
GOOGLE_API_KEY=

# ── SERVIDOR ──────────────────────────────────────────────────────────────────
# Puerto en el que escuchará el servidor Flask (Render lo inyecta automáticamente)
PORT=5000

# ── CORS ──────────────────────────────────────────────────────────────────────
# URLs de frontend permitidas (separadas por coma, sin espacios)
# Ejemplo producción: https://eluxar.onrender.com,https://eluxar.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── BACKEND ───────────────────────────────────────────────────────────────────
# URL base del backend Spring Boot
BACKEND_BASE=http://localhost:8080/api

# ── CLIPDROP API ───────────────────────────────────────────────────────────────
# API Key de Clipdrop para reemplazo de fondo en imágenes de productos.
# Obtener en: https://clipdrop.co/apis
CLIPDROP_API_KEY=

# ── MCP SERVER (opcional) ────────────────────────────────────────────────────
# Ruta al ejecutable Python del servidor MCP.
# En Linux/Render: déjalo vacío (usará el "python" del sistema).
# En Windows local: se detecta automáticamente el venv.
# MCP_PYTHON_PATH=python

# Ruta al script del servidor MCP (se auto-detecta si no se define).
# MCP_SERVER_PATH=/app/server/server.py