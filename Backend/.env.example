# ==============================================================
# ELUXAR BACKEND — Variables de Entorno (TEMPLATE)
# ==============================================================
# Copia este archivo como ".env" y rellena con tus credenciales.
# NO subas el .env real a Git.
# ==============================================================

# ── BASE DE DATOS ──────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/eluxar_db
DB_USERNAME=postgres
DB_PASSWORD=TU_PASSWORD_AQUI

# ── SEGURIDAD JWT ──────────────────────────────────────────────
JWT_SECRET=TU_SECRET_AQUI_MIN_32_CHARS
JWT_EXPIRATION=86400000

# ── CORS ───────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── GOOGLE OAUTH2 ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=TU_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# ── EMAIL — Resend API ─────────────────────────────────────────
RESEND_API_KEY=re_TU_API_KEY_AQUI
RESEND_FROM=Eluxar <onboarding@resend.dev>

# ── IMAGEKIT ───────────────────────────────────────────────────
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/TU_ID
IMAGEKIT_PUBLIC_KEY=public_TU_PUBLIC_KEY
IMAGEKIT_PRIVATE_KEY=private_TU_PRIVATE_KEY

# ── STABILITY AI ───────────────────────────────────────────────
STABILITY_API_KEY=sk-TU_API_KEY_AQUI

# ── CLOUDINARY ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=TU_CLOUD_NAME
CLOUDINARY_API_KEY=TU_API_KEY
CLOUDINARY_API_SECRET=TU_API_SECRET

# ── MERCADO PAGO ───────────────────────────────────────────────
# Usa credenciales TEST para sandbox, PROD para producción
MP_ACCESS_TOKEN=TEST-TU_ACCESS_TOKEN_AQUI
MP_PUBLIC_KEY=TEST-TU_PUBLIC_KEY_AQUI
